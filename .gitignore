# Prerequisites (original)
*.d

# Object files (original)
*.o
*.ko
*.obj
*.elf

# Linker output (original)
*.ilk
*.map
*.exp

# Precompiled Headers (original)
*.gch
*.pch

# Libraries (original)
*.lib
*.a
*.la
*.lo

# Shared objects (original)
*.dll
*.so
*.so.*
*.dylib

# Executables (original)
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files (original)
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results (original)
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# ----- CMake build artifacts -----
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Makefile               # generated by CMake for Makefile generators
compile_commands.json  # often regenerated, ignore to avoid clutter
*.cmake                # only if you don't have custom CMake modules; be careful

# ----- VS Code -----
.vscode/*
# Keep only specific configs if you deliberately share them:
# !.vscode/settings.json
# !.vscode/tasks.json
!.vscode/launch.json

# ----- STM32CubeIDE / Eclipse remnants (if CubeMX ever generated them) -----
.project
.cproject
.settings/

# ----- CubeMX temporary / backup files -----
*.mxproject
*.bak
*.Backup
*.savedState

# ----- Binary outputs that might appear -----
*.bin
*.dfu
*.elf           # already above, but harmless to repeat
*.hex           # already above
*.srec

# ----- OS generated files -----
.DS_Store
Thumbs.db

.clangd